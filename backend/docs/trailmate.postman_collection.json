{
  "info": {
    "name": "TrailMate API",
    "description": "Campus navigation backend. Set collection variables base_url, access_token, refresh_token. Login writes tokens automatically via its test script.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000" },
    { "key": "access_token", "value": "" },
    { "key": "refresh_token", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register (student)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Sample Student\",\n  \"email\": \"student@example.com\",\n  \"password\": \"Passw0rd!x\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const b = pm.response.json();",
                  "pm.collectionVariables.set('access_token', b.access_token);",
                  "pm.collectionVariables.set('refresh_token', b.refresh_token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/x-www-form-urlencoded" }
            ],
            "url": "{{base_url}}/auth/login",
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "username", "value": "admin@trailmate.dev" },
                { "key": "password", "value": "Admin@123" }
              ]
            }
          }
        },
        {
          "name": "Refresh",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/refresh",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            }
          }
        },
        { "name": "Me", "request": { "method": "GET", "url": "{{base_url}}/auth/me" } }
      ]
    },
    {
      "name": "Buildings",
      "item": [
        { "name": "List", "request": { "method": "GET", "url": "{{base_url}}/buildings" } },
        {
          "name": "Create",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/buildings",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Block\",\n  \"description\": \"...\",\n  \"lat\": 9.5133,\n  \"lng\": 76.5421\n}"
            }
          }
        },
        {
          "name": "Update",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/buildings/1",
            "body": { "mode": "raw", "raw": "{\n  \"description\": \"Updated\"\n}" }
          }
        },
        { "name": "Delete", "request": { "method": "DELETE", "url": "{{base_url}}/buildings/1" } }
      ]
    },
    {
      "name": "Departments",
      "item": [
        { "name": "List", "request": { "method": "GET", "url": "{{base_url}}/departments" } },
        {
          "name": "Create",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/departments",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"CSE\",\n  \"building_id\": 1\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Rooms",
      "item": [
        { "name": "List", "request": { "method": "GET", "url": "{{base_url}}/rooms" } },
        {
          "name": "Create",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/rooms",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"CS-101\",\n  \"type\": \"classroom\",\n  \"floor\": 1,\n  \"building_id\": 1\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Checkpoints",
      "item": [
        { "name": "List", "request": { "method": "GET", "url": "{{base_url}}/checkpoints" } },
        {
          "name": "Create",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/checkpoints",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"label\": \"Main Gate\",\n  \"lat\": 9.5125,\n  \"lng\": 76.5410,\n  \"building_id\": null\n}"
            }
          }
        },
        {
          "name": "Generate QR",
          "request": { "method": "POST", "url": "{{base_url}}/checkpoints/1/qr" }
        },
        {
          "name": "Download QR PNG",
          "request": { "method": "GET", "url": "{{base_url}}/checkpoints/1/qr.png" }
        }
      ]
    },
    {
      "name": "Edges",
      "item": [
        { "name": "List", "request": { "method": "GET", "url": "{{base_url}}/edges" } },
        {
          "name": "Create",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/edges",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"checkpoint_a_id\": 1,\n  \"checkpoint_b_id\": 2,\n  \"distance_meters\": 85,\n  \"walking_time_estimate_sec\": 61,\n  \"is_indoor\": false\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Navigation",
      "item": [
        {
          "name": "Route",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/route?from_id=1&to_id=10",
              "host": ["{{base_url}}"],
              "path": ["route"],
              "query": [
                { "key": "from_id", "value": "1" },
                { "key": "to_id", "value": "10" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Sync",
      "item": [
        { "name": "Get snapshot", "request": { "method": "GET", "url": "{{base_url}}/sync/snapshot" } },
        { "name": "Publish snapshot", "request": { "method": "POST", "url": "{{base_url}}/sync/snapshot" } }
      ]
    }
  ]
}
